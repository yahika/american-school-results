# Database
# Local development:
DATABASE_URL="file:./dev.db"
# Production (Supabase/Neon/Railway Postgres):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# JWT secret — generate with: openssl rand -base64 32
JWT_SECRET="your-strong-random-secret-here"

# WhatsApp notifications via UltraMsg (https://ultramsg.com)
# 1. Sign up at ultramsg.com
# 2. Create an instance and connect your WhatsApp phone by scanning the QR code
# 3. Copy your Instance ID and Token below
ULTRAMSG_INSTANCE="instance12345"
ULTRAMSG_TOKEN="your_ultramsg_token_here"
